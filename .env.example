# Copy to .env.local for local Vercel dev: `npx vercel env pull` or paste values manually.

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend (https://resend.com/api-keys) — never expose in the browser
RESEND_API_KEY=re_your_key
# Must be a sender you verified in Resend (domain or onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=Basinfoundry <bookings@yourdomain.com>

# Where to receive new submission notifications
NOTIFY_EMAIL=andrej@spenatlabs.com
